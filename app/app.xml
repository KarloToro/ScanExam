<file path="utilitarios/validacion_plantilla/validar_centros.py">
  1: # validar_centros.py
  2: 
  3: import json, time
  4: from pathlib import Path
  5: 
  6: import cv2
  7: 
  8: 
  9: TEMPLATE_ID = "ficha_optica_a5_horizontal_v1"
 10: 
 11: DRAW_CROP_BOX = True
 12: DRAW_LABELS = False
 13: 
 14: # Colores en formato BGR porque OpenCV usa BGR, no RGB
 15: COLOR_RESPUESTAS = (0, 180, 0)          # verde
 16: COLOR_IDENTIFICACION = (255, 120, 0)    # azul claro/naranja visual
 17: COLOR_MARCADORES = (0, 0, 255)          # rojo
 18: COLOR_CROP = (180, 180, 180)            # gris
 19: COLOR_TEXT = (237, 40, 237)             # morado
 20: 
 21: 
 22: def encontrar_raiz_proyecto() -> Path:
 23:     actual = Path(__file__).resolve()
 24: 
 25:     for parent in actual.parents:
 26:         if (parent / "README.md").exists() and (parent / "requirements.txt").exists():
 27:             return parent
 28: 
 29:     raise RuntimeError(
 30:         "No se pudo encontrar la raíz del proyecto. "
 31:         "Verifica que README.md y requirements.txt existan en la raíz."
 32:     )
 33: 
 34: 
 35: def cargar_json(path: Path) -> dict:
 36:     if not path.exists():
 37:         raise FileNotFoundError(f"No se encontró el archivo: {path}")
 38: 
 39:     with path.open("r", encoding="utf-8") as file:
 40:         return json.load(file)
 41: 
 42: 
 43: def resolver_ruta(template_dir: Path, relative_path: str) -> Path:
 44:     return template_dir / relative_path
 45: 
 46: 
 47: def validar_tamano_imagen(image, expected_width: int, expected_height: int):
 48:     height, width = image.shape[:2]
 49: 
 50:     if width != expected_width or height != expected_height:
 51:         raise ValueError(
 52:             "La imagen de referencia no coincide con canonical_size.\n"
 53:             f"Esperado: {expected_width}x{expected_height}px\n"
 54:             f"Encontrado: {width}x{height}px\n"
 55:             "Exporta plantilla_referencia.png desde Figma con el tamaño exacto."
 56:         )
 57: 
 58: 
 59: def extraer_marcadores(markers_data: dict) -> dict:
 60:     """
 61:     Soporta dos formatos:
 62: 
 63:     Formato recomendado:
 64:     {
 65:         "marker_size_px": 100,
 66:         "coordinate_type": "center",
 67:         "markers": {
 68:             "top_left": [180, 180],
 69:             ...
 70:         },
 71:         "orientation_marker": "top_right"
 72:     }
 73: 
 74:     Formato simple:
 75:     {
 76:         "top_left": [180, 180],
 77:         "top_right": [1920, 180],
 78:         ...
 79:     }
 80:     """
 81:     if "markers" in markers_data:
 82:         return markers_data["markers"]
 83: 
 84:     return {
 85:         key: value
 86:         for key, value in markers_data.items()
 87:         if isinstance(value, list) and len(value) == 2
 88:     }
 89: 
 90: 
 91: def punto_en_imagen(center, width: int, height: int) -> bool:
 92:     x, y = center
 93:     return 0 <= x < width and 0 <= y < height
 94: 
 95: 
 96: def dibujar_centro(
 97:     image,
 98:     bubble_id: str,
 99:     center,
100:     color,
101:     crop_size: int | None = None,
102:     draw_crop_box: bool = False,
103:     draw_label: bool = False,
104: ):
105:     cx, cy = int(round(center[0])), int(round(center[1]))
106: 
107:     # Punto central
108:     cv2.circle(image, (cx, cy), 5, color, thickness=-1)
109: 
110:     # Círculo guía alrededor del centro
111:     cv2.circle(image, (cx, cy), 12, color, thickness=2)
112: 
113:     # Caja de recorte esperada
114:     if draw_crop_box and crop_size is not None:
115:         half = crop_size // 2
116: 
117:         x1 = cx - half
118:         y1 = cy - half
119:         x2 = x1 + crop_size
120:         y2 = y1 + crop_size
121: 
122:         cv2.rectangle(image, (x1, y1), (x2, y2), COLOR_CROP, thickness=1)
123: 
124:     # Etiqueta opcional
125:     if draw_label:
126:         cv2.putText(
127:             image,
128:             bubble_id,
129:             (cx + 8, cy - 8),
130:             cv2.FONT_HERSHEY_SIMPLEX,
131:             0.35,
132:             COLOR_TEXT,
133:             1,
134:             cv2.LINE_AA,
135:         )
136: 
137: 
138: def validar_y_dibujar_grupo(
139:     image,
140:     centers: dict,
141:     group_name: str,
142:     color,
143:     crop_size: int | None,
144:     draw_crop_box: bool,
145:     draw_labels: bool,
146: ) -> list[str]:
147:     height, width = image.shape[:2]
148:     errores = []
149: 
150:     for item_id, center in centers.items():
151:         if not isinstance(center, list) or len(center) != 2:
152:             errores.append(f"{group_name}: {item_id} no tiene formato [x, y].")
153:             continue
154: 
155:         if not punto_en_imagen(center, width, height):
156:             errores.append(
157:                 f"{group_name}: {item_id} está fuera de imagen: {center}"
158:             )
159:             continue
160: 
161:         dibujar_centro(
162:             image=image,
163:             bubble_id=item_id,
164:             center=center,
165:             color=color,
166:             crop_size=crop_size,
167:             draw_crop_box=draw_crop_box,
168:             draw_label=draw_labels,
169:         )
170: 
171:     return errores
172: 
173: 
174: def main():
175:     inicio = time.perf_counter()
176:     project_root = encontrar_raiz_proyecto()
177: 
178:     template_dir = (
179:         project_root
180:         / "data"
181:         / "plantilla"
182:         / TEMPLATE_ID
183:     )
184: 
185:     template_config_path = template_dir / "template_config.json"
186:     config = cargar_json(template_config_path)
187: 
188:     canonical_width = config["canonical_size"]["width_px"]
189:     canonical_height = config["canonical_size"]["height_px"]
190: 
191:     reference_image_name = config["reference_files"]["template_image"]
192:     reference_image_path = resolver_ruta(template_dir, reference_image_name)
193: 
194:     answers_path = resolver_ruta(
195:         template_dir,
196:         config["answers"]["centers_file"]
197:     )
198: 
199:     student_id_path = resolver_ruta(
200:         template_dir,
201:         config["student_id"]["centers_file"]
202:     )
203: 
204:     markers_path = resolver_ruta(
205:         template_dir,
206:         config["perspective"]["markers_file"]
207:     )
208: 
209:     output_dir = project_root / "docs" / "evidencia_capturas"
210:     output_dir.mkdir(parents=True, exist_ok=True)
211: 
212:     output_path = output_dir / "validacion_centros_v1.png"
213: 
214:     image = cv2.imread(str(reference_image_path))
215: 
216:     if image is None:
217:         raise FileNotFoundError(
218:             f"No se pudo cargar la imagen de referencia: {reference_image_path}"
219:         )
220: 
221:     validar_tamano_imagen(
222:         image=image,
223:         expected_width=canonical_width,
224:         expected_height=canonical_height,
225:     )
226: 
227:     answers_centers = cargar_json(answers_path)
228:     student_id_centers = cargar_json(student_id_path)
229:     markers_data = cargar_json(markers_path)
230:     markers_centers = extraer_marcadores(markers_data)
231: 
232:     crop_size = config["bubble"]["crop_size_px"]
233: 
234:     errores = []
235: 
236:     errores += validar_y_dibujar_grupo(
237:         image=image,
238:         centers=answers_centers,
239:         group_name="respuestas",
240:         color=COLOR_RESPUESTAS,
241:         crop_size=crop_size,
242:         draw_crop_box=DRAW_CROP_BOX,
243:         draw_labels=DRAW_LABELS,
244:     )
245: 
246:     errores += validar_y_dibujar_grupo(
247:         image=image,
248:         centers=student_id_centers,
249:         group_name="identificacion",
250:         color=COLOR_IDENTIFICACION,
251:         crop_size=crop_size,
252:         draw_crop_box=DRAW_CROP_BOX,
253:         draw_labels=DRAW_LABELS,
254:     )
255: 
256:     errores += validar_y_dibujar_grupo(
257:         image=image,
258:         centers=markers_centers,
259:         group_name="marcadores",
260:         color=COLOR_MARCADORES,
261:         crop_size=None,
262:         draw_crop_box=False,
263:         draw_labels=True,
264:     )
265: 
266:     cv2.imwrite(str(output_path), image)
267: 
268:     print("Validación visual generada correctamente:")
269:     print(output_path)
270:     print()
271: 
272:     print("Resumen:")
273:     print(f"- Respuestas: {len(answers_centers)} centros")
274:     print(f"- Identificación: {len(student_id_centers)} centros")
275:     print(f"- Marcadores: {len(markers_centers)} centros")
276:     print(f"- Crop size usado: {crop_size}px")
277:     print()
278: 
279:     if errores:
280:         print("Advertencias encontradas:")
281:         for error in errores:
282:             print(f"- {error}")
283:     else:
284:         print("No se encontraron errores de formato ni puntos fuera de imagen.")
285:     fin = time.perf_counter()
286:     tiempo_total = fin - inicio
287:     print(f"Tiempo de ejecución: {tiempo_total:.4f} segundos")
288: 
289: if __name__ == "__main__":
290:     main()

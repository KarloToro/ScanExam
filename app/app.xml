1024: def _guardar_canonica_png(
1025:     canonical_image: np.ndarray,
1026:     output_root: str | Path,
1027:     filename: str | None,
1028: ) -> tuple[Path, str]:
1029:     """
1030:     Guarda la ficha canonizada como PNG en {output_root}/normalized/
1031:     (Decisión 2 y 3 del equipo). Retorna (path_absoluto,
1032:     path_para_manifest), donde path_para_manifest se arma prefijado
1033:     con el nombre de carpeta de output_root (p. ej. "work/normalized/
1034:     ficha_001.png"), tal como muestra el ejemplo de vision_manifest.json
1035:     acordado con el equipo.
1036:     """
1037:     output_root = Path(output_root)
1038:     normalized_dir = output_root / "normalized"
1039:     normalized_dir.mkdir(parents=True, exist_ok=True)
1040: 
1041:     stem = Path(filename).stem if filename else "ficha"
1042:     png_path = normalized_dir / f"{stem}.png"
1043: 
1044:     cv2.imwrite(str(png_path), canonical_image)
1045: 
1046:     path_for_manifest = str(
1047:         Path(output_root.name) / "normalized" / f"{stem}.png"
1048:     ).replace("\\", "/")
1049: 
1050:     return png_path, path_for_manifest
1051: 

 1: # generar_json_centros.py
 2: 
 3: import json
 4: from pathlib import Path
 5: 
 6: BUBBLE_SIZE = 48
 7: 
 8: BASE_DIR = Path(__file__).resolve().parent
 9: 
10: INPUT_TXT = BASE_DIR / "scanexam_respuestas_xy.txt"
11: OUTPUT_JSON = BASE_DIR / "scanexam_respuestas_centros.json"
12: 
13: 
14: def parse_line(line: str, line_number: int):
15:     line = line.strip()
16: 
17:     if not line or line.startswith("#"):
18:         return None
19: 
20:     parts = [part.strip() for part in line.split(",")]
21: 
22:     if len(parts) != 3:
23:         raise ValueError(
24:             f"Línea {line_number}: formato inválido. Usa: id,x,y"
25:         )
26: 
27:     bubble_id, x_raw, y_raw = parts
28: 
29:     try:
30:         x = float(x_raw)
31:         y = float(y_raw)
32:     except ValueError:
33:         raise ValueError(
34:             f"Línea {line_number}: X e Y deben ser numéricos."
35:         )
36: 
37:     return bubble_id, x, y
38: 
39: 
40: def main():
41:     input_path = INPUT_TXT
42:     output_path = OUTPUT_JSON
43: 
44:     if not input_path.exists():
45:         raise FileNotFoundError(
46:             f"No se encontró {input_path}"
47:         )
48: 
49:     half = BUBBLE_SIZE / 2
50:     centers = {}
51: 
52:     with input_path.open("r", encoding="utf-8") as file:
53:         for line_number, line in enumerate(file, start=1):
54:             parsed = parse_line(line, line_number)
55: 
56:             if parsed is None:
57:                 continue
58: 
59:             bubble_id, x, y = parsed
60: 
61:             if bubble_id in centers:
62:                 raise ValueError(
63:                     f"Línea {line_number}: id repetido: {bubble_id}"
64:                 )
65: 
66:             cx = round(x + half)
67:             cy = round(y + half)
68: 
69:             centers[bubble_id] = [cx, cy]
70: 
71:     with output_path.open("w", encoding="utf-8") as file:
72:         json.dump(centers, file, indent=4, ensure_ascii=False)
73: 
74:     print("JSON generado correctamente:")
75:     print(output_path)
76:     print()
77:     print(json.dumps(centers, indent=4, ensure_ascii=False))
78: 
79: 
80: if __name__ == "__main__":
81:     main()
</file>


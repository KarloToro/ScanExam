 866: def process_ficha(
 867:     image: np.ndarray | str | Path,
 868:     template_id: str = config.TEMPLATE_ID,
 869:     output_root: str | Path | None = None,
 870:     original_filename: str | None = None,
 871: ) -> FichaProcessingResult:
 872:     """
 873:     Punto de entrada único de P2. Recibe una foto cruda (ruta o imagen
 874:     ya cargada con cv2) y devuelve la imagen canónica lista para P3, o
 875:     un ERROR con el motivo técnico si la ficha no pudo procesarse.
 876: 
 877:     Si se pasa output_root (Decisión 3 del equipo), además:
 878:         - guarda la ficha canonizada como PNG en
 879:           {output_root}/normalized/{nombre}.png
 880:         - deja lista la entrada de vision_manifest.json en
 881:           resultado.manifest_entry (proceso_batch() la usa para
 882:           escribir el manifest completo del lote).
 883: 
 884:     output_root representa la carpeta "work/" del lote (no
 885:     BATCH-001/ completo): P2 no conoce ni construye la estructura
 886:     completa del batch, solo escribe dentro de la carpeta que se le

 420: # ---------------------------------------------------------------------------
 421: # Fase 2: corrección de perspectiva (warp a imagen canónica)
 422: # ---------------------------------------------------------------------------
 423: 
 424: @dataclass
 425: class WarpResult:
 426:     """
 427:     Resultado de la corrección de perspectiva sobre una foto cruda ya
 428:     con marcadores detectados (status == "OK" en MarkerDetectionResult).
 429: 
 430:     status:
 431:         "OK"           -> se generó la imagen canónica correctamente.
 432:         "WARP_FAILED"  -> la homografía no pudo calcularse o el
 433:                           resultado no pasó las validaciones mínimas
 434:                           de sanidad.
 435:     """
 436: 
 437:     status: str
 438:     issue_code: str | None
 439:     message: str
 440:     canonical_image: np.ndarray | None = None
 441:     homography: np.ndarray | None = None
 442: 
 443: 
 444: def correct_perspective(
 445:     image: np.ndarray,
 446:     detected_points: dict[str, tuple[float, float]],
 447:     marker_centers: dict[str, list[int]],
 448:     canonical_width: int,
 449:     canonical_height: int,
 450: ) -> WarpResult:
 451:     """
 452:     Corrige la perspectiva de la foto cruda y la transforma a la imagen
 453:     canónica, usando los 4 marcadores detectados (Fase 1) como origen y
 454:     las coordenadas oficiales de marcadores_centros.json como destino.
 455: 
 456:     Parámetros:
 457:         image: foto cruda original (BGR).
 458:         detected_points: "ordered_points" de un MarkerDetectionResult
 459:             con status == "OK" (top_left/top_right/bottom_left/bottom_right
 460:             en la foto cruda).
 461:         marker_centers: centros oficiales de marcadores en la imagen
 462:             canónica (viene de TemplateContract.marker_centers, es decir,
 463:             de marcadores_centros.json vía template_loader).
 464:         canonical_width / canonical_height: tamaño de salida esperado
 465:             (TemplateContract.canonical_width / canonical_height).
 466: 
 467:     Retorna:
 468:         WarpResult
 469:     """
 470:     missing_keys = [
 471:         key for key in config.WARP_POINT_ORDER
 472:         if key not in detected_points or key not in marker_centers
 473:     ]
 474: 
 475:     if missing_keys:
 476:         return WarpResult(
 477:             status="WARP_FAILED",
 478:             issue_code=config.WARP_FAILED_ISSUE_CODE,
 479:             message=(
 480:                 "Faltan puntos de referencia para calcular la homografía: "
 481:                 f"{', '.join(missing_keys)}."
 482:             ),
 483:         )
 484: 
 485:     src_points = np.array(
 486:         [detected_points[key] for key in config.WARP_POINT_ORDER],
 487:         dtype=np.float32,
 488:     )
 489: 
 490:     dst_points = np.array(
 491:         [marker_centers[key] for key in config.WARP_POINT_ORDER],
 492:         dtype=np.float32,
 493:     )
 494: 
 495:     # Un cuadrilátero degenerado (puntos casi colineales, área ~0) no
 496:     # puede producir una homografía válida.
 497:     src_area = cv2.contourArea(src_points)
 498: 
 499:     if src_area <= 0:
 500:         return WarpResult(
 501:             status="WARP_FAILED",
 502:             issue_code=config.WARP_FAILED_ISSUE_CODE,
 503:             message=(
 504:                 "Los 4 puntos de origen no forman un cuadrilátero válido "
 505:                 "(área nula o puntos colineales)."
 506:             ),
 507:         )
 508: 
 509:     try:
 510:         homography = cv2.getPerspectiveTransform(src_points, dst_points)
 511:     except cv2.error as error:
 512:         return WarpResult(
 513:             status="WARP_FAILED",
 514:             issue_code=config.WARP_FAILED_ISSUE_CODE,
 515:             message=f"No se pudo calcular la homografía: {error}",
 516:         )
 517: 
 518:     canonical_image = cv2.warpPerspective(
 519:         image,
 520:         homography,
 521:         (canonical_width, canonical_height),
 522:     )
 523: 
 524:     # Validación mínima de sanidad: si el resultado es casi completamente
 525:     # negro, algo salió mal en el mapeo (orden de puntos incorrecto,
 526:     # homografía degenerada, etc.). La validación exhaustiva de zonas
 527:     # negras vive en la métrica M3 (Fase 3).
 528:     mean_intensity = float(
 529:         cv2.cvtColor(canonical_image, cv2.COLOR_BGR2GRAY).mean()
 530:     )
 531: 
 532:     if mean_intensity < config.WARP_MIN_MEAN_GRAY_INTENSITY:
 533:         return WarpResult(
 534:             status="WARP_FAILED",
 535:             issue_code=config.WARP_FAILED_ISSUE_CODE,
 536:             message=(
 537:                 "La imagen canónica resultante es casi completamente "
 538:                 f"negra (intensidad promedio: {mean_intensity:.1f}). "
 539:                 "La homografía probablemente es incorrecta."
 540:             ),
 541:             homography=homography,
 542:         )
 543: 
 544:     return WarpResult(
 545:         status="OK",
 546:         issue_code=None,
 547:         message="Perspectiva corregida correctamente.",
 548:         canonical_image=canonical_image,
 549:         homography=homography,
 550:     )
 551: 
 552: 
 553: def extraer_recorte(
 554:     canonical_image: np.ndarray,
 555:     center: list[int] | tuple[float, float],
 556:     crop_size: int,
 557: ) -> np.ndarray:
 558:     """
 559:     Helper de apoyo (Decisión 4 del equipo, ver 01_modulo_cv.md): recibe
 560:     la imagen canonizada, un centro [x, y] y un tamaño de recorte, y
 561:     devuelve el crop cuadrado alrededor de ese centro.
 562: 
 563:     Recorrer todos los centros de respuestas_centros.json /
 564:     identificacion_centros.json, generar todos los crops y construir
 565:     crop_manifest.json es responsabilidad de P3 — esta función solo
 566:     resuelve el recorte individual.
 567: 
 568:     Si el centro está cerca del borde de la imagen, el recorte se
 569:     desplaza lo necesario para mantener exactamente crop_size x
 570:     crop_size en vez de devolver un recorte más chico.
 571:     """
 572:     cx, cy = center
 573:     half = crop_size // 2
 574:     height, width = canonical_image.shape[:2]
 575: 
 576:     x1 = int(round(cx)) - half
 577:     y1 = int(round(cy)) - half
 578: 
 579:     # Si el crop se sale por un borde, se desplaza para conservar el
 580:     # tamaño exacto (en vez de recortar el crop resultante).
 581:     x1 = max(0, min(x1, width - crop_size))
 582:     y1 = max(0, min(y1, height - crop_size))
 583: 
 584:     x2 = x1 + crop_size
 585:     y2 = y1 + crop_size
 586: 
 587:     return canonical_image[y1:y2, x1:x2].copy()
 588: 

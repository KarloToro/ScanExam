 58: def _build_synthetic_photo(
 59:     plantilla_referencia: np.ndarray,
 60:     dst_corners: list[list[int]],
 61:     brightness_factor: float = 1.0,
 62:     canvas_size: tuple[int, int] = (3000, 2400),
 63: ) -> np.ndarray:
 64:     """
 65:     Simula una "foto" aplicando una perspectiva conocida sobre la
 66:     plantilla de referencia perfecta, opcionalmente oscurecida para
 67:     imitar la exposición real de una cámara (la plantilla digital pura
 68:     es más blanca que cualquier foto real).
 69:     """
 70:     h, w = plantilla_referencia.shape[:2]
 71:     canvas_w, canvas_h = canvas_size
 72: 
 73:     src_corners = np.array([[0, 0], [w, 0], [w, h], [0, h]], dtype=np.float32)
 74:     dst = np.array(dst_corners, dtype=np.float32)
 75: 
 76:     homography = cv2.getPerspectiveTransform(src_corners, dst)
 77: 
 78:     source = plantilla_referencia
 79: 
 80:     if brightness_factor != 1.0:
 81:         source = np.clip(
 82:             plantilla_referencia.astype(np.float32) * brightness_factor, 0, 255
 83:         ).astype(np.uint8)
 84: 
 85:     return cv2.warpPerspective(
 86:         source, homography, (canvas_w, canvas_h), borderValue=(180, 180, 180)
 87:     )

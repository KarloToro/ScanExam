 254: 
 255: def _find_square_candidates(
 256:     gray: np.ndarray,
 257:     width: int,
 258:     height: int,
 259: ) -> list[MarkerCandidate]:
 260:     """
 261:     Busca contornos cuadrados oscuros que puedan ser marcadores de
 262:     referencia, en cualquier parte de la imagen.
 263:     """
 264:     # Otsu separa razonablemente bien "hoja blanca" de "marcador negro"
 265:     # en condiciones normales de iluminación.
 266:     blurred = cv2.GaussianBlur(gray, (5, 5), 0)
 267:     _, binary = cv2.threshold(
 268:         blurred, 0, 255, cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU
 269:     )
 270: 
 271:     contours, hierarchy = cv2.findContours(
 272:         binary, cv2.RETR_TREE, cv2.CHAIN_APPROX_SIMPLE
 273:     )
 274: 
 275:     if hierarchy is None:
 276:         return []
 277: 
 278:     hierarchy = hierarchy[0]  # cv2 envuelve la jerarquía en un array extra
 279:     image_area = float(width * height)
 280: 
 281:     min_area = image_area * config.MARKER_MIN_AREA_RATIO
 282:     max_area = image_area * config.MARKER_MAX_AREA_RATIO
 283: 
 284:     candidates: list[MarkerCandidate] = []
 285: 
 286:     for index, contour in enumerate(contours):
 287:         area = cv2.contourArea(contour)
 288: 
 289:         if area < min_area or area > max_area:
 290:             continue
 291: 
 292:         perimeter = cv2.arcLength(contour, True)
 293:         epsilon = config.MARKER_POLY_APPROX_EPSILON_RATIO * perimeter
 294:         approx = cv2.approxPolyDP(contour, epsilon, True)
 295: 
 296:         if len(approx) != 4 or not cv2.isContourConvex(approx):
 297:             continue
 298: 
 299:         x, y, w, h = cv2.boundingRect(approx)
 300: 
 301:         if h == 0:
 302:             continue
 303: 
 304:         aspect_ratio = w / h
 305:         tol = config.MARKER_ASPECT_RATIO_TOLERANCE
 306: 
 307:         if not (1 - tol <= aspect_ratio <= 1 + tol):
 308:             continue
 309: 
 310:         center = (x + w / 2.0, y + h / 2.0)
 311:         has_hole = _has_inner_hole(index, hierarchy, contours, min_area)
 312: 
 313:         candidates.append(
 314:             MarkerCandidate(
 315:                 contour=approx,
 316:                 center=center,
 317:                 area=area,
 318:                 bbox=(x, y, w, h),
 319:                 has_inner_hole=has_hole,
 320:             )
 321:         )
 322: 
 323:     return candidates
 324: 
 325: 
 326: def _has_inner_hole(
 327:     contour_index: int,
 328:     hierarchy: np.ndarray,
 329:     contours: list[np.ndarray],
 330:     min_child_area: float,
 331: ) -> bool:
 332:     """
 333:     Revisa si el contorno tiene al menos un hijo (hueco interior) con
 334:     área significativa. Esto distingue al marcador de orientación
 335:     (cuadrado negro con cuadrado claro adentro) de los 3 marcadores
 336:     sólidos.
 337: 
 338:     hierarchy[i] = [next, previous, first_child, parent]
 339:     """
 340:     first_child = hierarchy[contour_index][2]
 341: 
 342:     child_index = first_child
 343:     while child_index != -1:
 344:         child_area = cv2.contourArea(contours[child_index])
 345: 
 346:         # El hueco debe ser una fracción razonable del marcador padre,
 347:         # no ruido de compresión/JPEG.
 348:         if child_area >= min_child_area * 0.15:
 349:             return True
 350: 
 351:         child_index = hierarchy[child_index][0]  # siguiente hermano
 352: 
 353:     return False
 354: 
 355: 
 356: def _hull_area(centers: list[tuple[float, float]]) -> float:
 357:     """Área del cuadrilátero convexo formado por 4 (o más) puntos."""
 358:     points = np.array(centers, dtype=np.float32)
 359:     hull = cv2.convexHull(points)
 360:     return cv2.contourArea(hull)
 361: 
 362: 
 363: def _select_best_quad(
 364:     candidates: list[MarkerCandidate],
 365: ) -> list[MarkerCandidate] | None:
 366:     """
 367:     De entre todos los candidatos cuadrados detectados, selecciona el
 368:     grupo de 4 que forma el cuadrilátero convexo de mayor área.
 369: 
 370:     Esto es deliberadamente independiente de la posición del candidato
 371:     dentro del encuadre de la foto (a diferencia de un enfoque por
 372:     zonas fijas), porque en fotos reales la hoja rara vez llena todo
 373:     el encuadre y puede estar rotada o inclinada. También permite
 374:     ignorar ruido o una segunda ficha parcialmente visible, ya que la
 375:     ficha principal en primer plano casi siempre forma el
 376:     cuadrilátero más grande.
 377:     """
 378:     if len(candidates) < 4:
 379:         return None
 380: 
 381:     if len(candidates) == 4:
 382:         return candidates
 383: 
 384:     best_group: tuple[MarkerCandidate, ...] | None = None
 385:     best_area = -1.0
 386: 
 387:     for group in combinations(candidates, 4):
 388:         area = _hull_area([c.center for c in group])
 389: 
 390:         if area > best_area:
 391:             best_area = area
 392:             best_group = group
 393: 
 394:     return list(best_group) if best_group is not None else None
 395: 
 396: 
 397: def _order_candidates_by_geometry(
 398:     candidates: list[MarkerCandidate],
 399: ) -> dict[str, MarkerCandidate]:
 400:     """
 401:     Ordena 4 candidatos como top_left/top_right/bottom_left/bottom_right
 402:     usando la heurística estándar de suma/diferencia de coordenadas.
 403:     Es robusta a inclinación y a que la hoja no esté perfectamente
 404:     encuadrada, porque compara los candidatos entre sí en vez de contra
 405:     posiciones fijas del frame completo.
 406:     """
 407:     centers = np.array([c.center for c in candidates], dtype=np.float32)
 408:     sums = centers.sum(axis=1)
 409:     diffs = centers[:, 0] - centers[:, 1]  # x - y
 410: 
 411:     return {
 412:         "top_left": candidates[int(np.argmin(sums))],
 413:         "bottom_right": candidates[int(np.argmax(sums))],
 414:         "top_right": candidates[int(np.argmax(diffs))],
 415:         "bottom_left": candidates[int(np.argmin(diffs))],
 416:     }
 417: 

  7: def encontrar_raiz_proyecto() -> Path:
  8:     """
  9:     Busca la raíz del proyecto subiendo carpetas hasta encontrar
 10:     archivos característicos del repo.
 11:     """
 12:     actual = Path(__file__).resolve()
 13: 
 14:     for parent in actual.parents:
 15:         if (parent / "README.md").exists() and (parent / "requirements.txt").exists():
 16:             return parent
 17: 
 18:     raise RuntimeError(
 19:         "No se pudo encontrar la raíz del proyecto. "
 20:         "Verifica que README.md y requirements.txt existan en la raíz."
 21:     )
 22: 
 23: 
 24: PROJECT_ROOT = encontrar_raiz_proyecto()
 25: 
 26: TEMPLATE_DIR = PROJECT_ROOT / "data" / "plantilla" / "ficha_optica_a5_horizontal_v1"
 27: OUTPUT_FILE = TEMPLATE_DIR / "template_config.json"
 28: 
 29: CANONICAL_WIDTH = 2100
 30: CANONICAL_HEIGHT = 1480
 31: 
 32: TEMPLATE_PDF = "FICHA_OPTICA_V1.pdf"
 33: TEMPLATE_IMAGE = "plantilla_referencia.png"
 34: 
 35: config = {
 36:     "schema_version": "1.0.0",
 37:     "template_id": "ficha_optica_a5_horizontal_v1",
 38:     "template_name": "Ficha Óptica A5 Horizontal v1",
 39: 
 40:     "canonical_size": {
 41:         "width_px": CANONICAL_WIDTH,
 42:         "height_px": CANONICAL_HEIGHT
 43:     },
 44: 
 45:     "canonical_view": {
 46:         "orientation": "landscape",
 47:         "orientation_es": "horizontal",
 48:         "reference_file": TEMPLATE_IMAGE,
 49:         "semantic_layout": {
 50:             "top": "encabezado de la ficha",
 51:             "left": "bloque de identificación del estudiante",
 52:             "right": "bloque de respuestas",
 53:             "orientation_marker_position": "top_right"
 54:         },
 55:         "pipeline_contract": (
 56:             "P2 debe transformar toda captura real a la imagen canónica definida "
 57:             "en canonical_size antes de que P3 use los centros de burbujas."
 58:         )
 59:     },
 60: 
 61:     "physical_size": {
 62:         "unit": "mm",
 63:         "width": 210,
 64:         "height": 148,
 65:         "px_per_mm": 10,
 66:         "dpi_reference": 254
 67:     },
 68: 
 69:     "coordinate_system": {
 70:         "applies_to": "canonical_image_after_perspective_correction",
 71:         "origin": "top_left",
 72:         "coordinate_order": "[x, y]",
 73:         "x_axis": "right",
 74:         "y_axis": "down",
 75:         "unit": "px",
 76:         "note": (
 77:             "Las coordenadas se interpretan únicamente sobre la imagen canónica "
 78:             "A5 horizontal. No aplicar sobre la foto cruda."
 79:         )
 80:     },
 81: 
 82:     "bubble": {
 83:         "diameter_px": 48,
 84:         "crop_size_px": 64,
 85:         "analysis_inner_radius_px": 16,
 86:         "center_source": (
 87:             "Centro = X + 24, Y + 24 desde la esquina superior izquierda "
 88:             "del círculo 48x48 en Figma."
 89:         )
 90:     },
 91: 
 92:     "student_id": {
 93:         "columns": 8,
 94:         "values": 10,
 95:         "id_pattern": "id_c{column:02d}_v{value}",
 96:         "reading_order": "c08_to_c01",
 97:         "centers_file": "identificacion_centros.json"
 98:     },
 99: 
100:     "answers": {
101:         "questions": 10,
102:         "options": ["A", "B", "C", "D", "E"],
103:         "id_pattern": "q_{question:02d}_{option}",
104:         "centers_file": "respuestas_centros.json"
105:     },
106: 
107:     "perspective": {
108:         "markers_file": "marcadores_centros.json",
109:         "output_size_px": [CANONICAL_WIDTH, CANONICAL_HEIGHT],
110:         "method": "homography",
111:         "note": (
112:             "Los marcadores se usan para corregir perspectiva y generar "
113:             "la imagen canónica antes de leer burbujas."
114:         )
115:     },
116: 
117:     "reference_files": {
118:         "template_pdf": TEMPLATE_PDF,
119:         "template_image": TEMPLATE_IMAGE
120:     }
121: }
122: 
123: 
124: def validar_archivos_requeridos():
125:     archivos = [
126:         TEMPLATE_DIR / TEMPLATE_PDF,
127:         TEMPLATE_DIR / TEMPLATE_IMAGE,
128:         TEMPLATE_DIR / "identificacion_centros.json",
129:         TEMPLATE_DIR / "respuestas_centros.json",
130:         TEMPLATE_DIR / "marcadores_centros.json",
131:     ]
132: 
133:     faltantes = [archivo for archivo in archivos if not archivo.exists()]
134: 
135:     if faltantes:
136:         print("Advertencia: faltan algunos archivos referenciados por el template:")
137:         for archivo in faltantes:
138:             print(f"- {archivo}")
139:         print()
140:     else:
141:         print("Todos los archivos referenciados existen.")
142: 
143: 
144: def main():
145:     TEMPLATE_DIR.mkdir(parents=True, exist_ok=True)
146: 
147:     validar_archivos_requeridos()
148: 
149:     with OUTPUT_FILE.open("w", encoding="utf-8") as file:
150:         json.dump(config, file, indent=4, ensure_ascii=False)
151: 
152:     print("template_config.json generado correctamente:")
153:     print(OUTPUT_FILE)
154: 
155: 
156: if __name__ == "__main__":
157:     main()

1154: def draw_marker_roi_debug(
1155:     canonical_image: np.ndarray,
1156:     marker_centers: dict[str, list[int]],
1157:     marker_size_px: int = 100,
1158: ) -> np.ndarray:
1159:     """
1160:     Genera un mosaico con la ROI de cada marcador (tal como la ve M4)
1161:     junto a su máscara de píxeles oscuros y el % de oscuridad medido.
1162:     Sirve para diagnosticar, esquina por esquina, por qué M4 pudo
1163:     fallar en una foto real (sombra, blur localizado, iluminación
1164:     desigual, etc.) en vez de solo ver el "None" en el resultado.
1165:     """
1166:     gray = cv2.cvtColor(canonical_image, cv2.COLOR_BGR2GRAY)
1167:     half = marker_size_px // 2 + config.QUALITY_MARKER_ROI_MARGIN
1168: 
1169:     rows = []
1170: 
1171:     for name, (cx, cy) in marker_centers.items():
1172:         x1 = max(0, int(cx - half))
1173:         y1 = max(0, int(cy - half))
1174:         x2 = min(gray.shape[1], int(cx + half))
1175:         y2 = min(gray.shape[0], int(cy + half))
1176: 
1177:         roi = gray[y1:y2, x1:x2]
1178: 
1179:         if roi.size == 0:
1180:             continue
1181: 
1182:         dark_mask = (roi < config.QUALITY_DARK_PIXEL_THRESHOLD).astype(np.uint8) * 255
1183:         dark_ratio = float((roi < config.QUALITY_DARK_PIXEL_THRESHOLD).sum()) / roi.size
1184: 
1185:         roi_bgr = cv2.cvtColor(roi, cv2.COLOR_GRAY2BGR)
1186:         mask_bgr = cv2.cvtColor(dark_mask, cv2.COLOR_GRAY2BGR)
1187:         row = np.hstack([roi_bgr, mask_bgr])
1188: 
1189:         label = (
1190:             f"{name}: {dark_ratio * 100:.1f}% oscuro "
1191:             f"(umbral {config.QUALITY_MIN_MARKER_DARK_RATIO * 100:.0f}%)"
1192:         )
1193:         label_bar = np.full((22, row.shape[1], 3), 255, dtype=np.uint8)
1194:         cv2.putText(
1195:             label_bar, label, (5, 16), cv2.FONT_HERSHEY_SIMPLEX,
1196:             0.45, (0, 0, 255), 1, cv2.LINE_AA,
1197:         )
1198: 
1199:         rows.append(np.vstack([label_bar, row]))
1200: 
1201:     if not rows:
1202:         return canonical_image.copy()
1203: 
1204:     max_width = max(row.shape[1] for row in rows)
1205:     padded_rows = []
1206: 
1207:     for row in rows:
1208:         if row.shape[1] < max_width:
1209:             pad = np.full((row.shape[0], max_width - row.shape[1], 3), 255, dtype=np.uint8)
1210:             row = np.hstack([row, pad])
1211:         padded_rows.append(row)
1212: 
1213:     return np.vstack(padded_rows)
1214: 

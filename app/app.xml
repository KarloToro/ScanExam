  45: # ---------------------------------------------------------------------------
  46: # Estructuras de datos
  47: # ---------------------------------------------------------------------------
  48: 
  49: @dataclass
  50: class MarkerCandidate:
  51:     """Un contorno cuadrado candidato a marcador de referencia."""
  52: 
  53:     contour: np.ndarray
  54:     center: tuple[float, float]
  55:     area: float
  56:     bbox: tuple[int, int, int, int]  # x, y, w, h
  57:     has_inner_hole: bool
  58: 
  59: 
  60: @dataclass
  61: class MarkerDetectionResult:
  62:     """
  63:     Resultado de la detección de marcadores sobre una foto cruda.
  64: 
  65:     status:
  66:         "OK"                  -> los 4 marcadores fueron ubicados y la
  67:                                   orientación es la esperada.
  68:         "MARKERS_NOT_FOUND"   -> no se pudo ubicar alguno de los 4
  69:                                   marcadores (o hay ambigüedad en cuál
  70:                                   es el marcador de orientación).
  71:         "INVALID_ORIENTATION" -> los 4 marcadores se ubicaron, pero el
  72:                                   marcador especial no está donde debería.
  73: 
  74:     ordered_points:
  75:         dict con las 4 llaves "top_left", "top_right", "bottom_left",
  76:         "bottom_right" -> (x, y) en la foto cruda. Solo viene poblado
  77:         cuando status == "OK". Este es el insumo directo para la
  78:         homografía de Fase 3.
  79:     """
  80: 
  81:     status: str
  82:     issue_code: str | None
  83:     message: str
  84:     ordered_points: dict[str, tuple[float, float]] | None = None
  85:     candidates: list[MarkerCandidate] = field(default_factory=list)
  86: 
  87: 
  88: # ---------------------------------------------------------------------------
  89: # Fase 1: detección de marcadores
  90: # ---------------------------------------------------------------------------
  91: 
  92: def detect_reference_markers(
  93:     image: np.ndarray,
  94:     orientation_marker: str = config.ORIENTATION_MARKER_POSITION,
  95: ) -> MarkerDetectionResult:
  96:     """
  97:     Detecta los 4 marcadores cuadrados de referencia sobre la foto cruda
  98:     y determina si la orientación coincide con la esperada.
  99: 
 100:     No asume ningún tamaño absoluto de marcador: filtra por forma
 101:     (cuadrado) y por proporción respecto al área total de la imagen,
 102:     ya que la foto puede tomarse a distintas distancias.
 103: 
 104:     Parámetros:
 105:         image: imagen BGR cargada con cv2.imread (foto cruda, sin
 106:             canonizar).
 107:         orientation_marker: nombre de la posición que debe tener el
 108:             marcador especial (con hueco interior). Por defecto se
 109:             toma de config.ORIENTATION_MARKER_POSITION, que debe
 110:             coincidir con "orientation_marker" en
 111:             marcadores_centros.json.
 112: 
 113:     Retorna:
 114:         MarkerDetectionResult
 115:     """
 116:     if image is None or image.size == 0:
 117:         return MarkerDetectionResult(
 118:             status="MARKERS_NOT_FOUND",
 119:             issue_code=config.MARKER_ISSUE_CODES["NOT_FOUND"],
 120:             message="La imagen recibida está vacía o no pudo cargarse.",
 121:         )
 122: 
 123:     height, width = image.shape[:2]
 124:     gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
 125: 
 126:     candidates = _find_square_candidates(gray, width, height)
 127: 
 128:     quad_candidates = _select_best_quad(candidates)
 129: 
 130:     if quad_candidates is None:
 131:         return MarkerDetectionResult(
 132:             status="MARKERS_NOT_FOUND",
 133:             issue_code=config.MARKER_ISSUE_CODES["NOT_FOUND"],
 134:             message=(
 135:                 "No se encontraron 4 candidatos cuadrados consistentes entre sí "
 136:                 f"(candidatos totales detectados: {len(candidates)})."
 137:             ),
 138:             candidates=candidates,
 139:         )
 140: 
 141:     corner_map = _order_candidates_by_geometry(quad_candidates)
 142: 
 143:     # ¿Cuál de los 4 candidatos elegidos tiene el hueco interior?
 144:     holed_corners = [
 145:         name for name, candidate in corner_map.items()
 146:         if candidate.has_inner_hole
 147:     ]
 148: 
 149:     if len(holed_corners) != 1:
 150:         return MarkerDetectionResult(
 151:             status="MARKERS_NOT_FOUND",
 152:             issue_code=config.MARKER_ISSUE_CODES["NOT_FOUND"],
 153:             message=(
 154:                 "No se pudo identificar de forma inequívoca el marcador de "
 155:                 f"orientación (candidatos con hueco interior: {len(holed_corners)}, "
 156:                 "se esperaba exactamente 1)."
 157:             ),
 158:             candidates=candidates,
 159:         )
 160: 
 161:     detected_orientation = holed_corners[0]
 162: 
 163:     ordered_points = {
 164:         name: candidate.center
 165:         for name, candidate in corner_map.items()
 166:     }
 167: 
 168:     if detected_orientation != orientation_marker:
 169:         return MarkerDetectionResult(
 170:             status="INVALID_ORIENTATION",
 171:             issue_code=config.MARKER_ISSUE_CODES["INVALID_ORIENTATION"],
 172:             message=(
 173:                 f"El marcador de orientación se ubicó en '{detected_orientation}', "
 174:                 f"pero se esperaba en '{orientation_marker}'. "
 175:                 "La ficha probablemente fue fotografiada rotada."
 176:             ),
 177:             ordered_points=ordered_points,
 178:             candidates=candidates,
 179:         )
 180: 
 181:     return MarkerDetectionResult(
 182:         status="OK",
 183:         issue_code=None,
 184:         message="Los 4 marcadores fueron detectados y la orientación es correcta.",
 185:         ordered_points=ordered_points,
 186:         candidates=candidates,
 187:     )
 188: 
 189: 
 190: def detect_and_autorotate(
 191:     image: np.ndarray,
 192: ) -> tuple[np.ndarray, MarkerDetectionResult, int]:
 193:     """
 194:     Envuelve detect_reference_markers() con auto-corrección de
 195:     orientación (Decisión 1 del equipo, ver 01_modulo_cv.md):
 196: 
 197:         Si la orientación puede resolverse de forma inequívoca
 198:         rotando 90°, 180° o 270°, se corrige automáticamente.
 199:         Si no se puede resolver con confianza, se devuelve
 200:         INVALID_ORIENTATION (o el error original si nunca se
 201:         encontraron los 4 marcadores).
 202: 
 203:     Retorna (imagen_final, resultado_deteccion, grados_rotados).
 204:     La imagen_final ya viene rotada si hubo auto-corrección; los
 205:     "ordered_points" de resultado_deteccion son relativos a esa
 206:     imagen_final, no a la imagen original.
 207:     """
 208:     original_result = detect_reference_markers(image)
 209: 
 210:     if original_result.status == "OK":
 211:         return image, original_result, 0
 212: 
 213:     rotation_flags = {
 214:         90: cv2.ROTATE_90_CLOCKWISE,
 215:         180: cv2.ROTATE_180,
 216:         270: cv2.ROTATE_90_COUNTERCLOCKWISE,
 217:     }
 218: 
 219:     resolved: list[tuple[int, np.ndarray, MarkerDetectionResult]] = []
 220: 
 221:     for degrees, flag in rotation_flags.items():
 222:         rotated_image = cv2.rotate(image, flag)
 223:         rotated_result = detect_reference_markers(rotated_image)
 224: 
 225:         if rotated_result.status == "OK":
 226:             resolved.append((degrees, rotated_image, rotated_result))
 227: 
 228:     if len(resolved) == 1:
 229:         degrees, rotated_image, rotated_result = resolved[0]
 230:         return rotated_image, rotated_result, degrees
 231: 
 232:     if len(resolved) == 0:
 233:         # No se pudo resolver en ninguna rotación: se conserva el
 234:         # motivo de falla original (MARKERS_NOT_FOUND o
 235:         # INVALID_ORIENTATION), tal como venía.
 236:         return image, original_result, 0
 237: 
 238:     # Más de una rotación "resuelve" la orientación: ambiguo, no se
 239:     # autocorrige con confianza (caso extremadamente improbable dado
 240:     # que solo hay 1 marcador especial, pero se cubre por seguridad).
 241:     ambiguous_result = MarkerDetectionResult(
 242:         status="INVALID_ORIENTATION",
 243:         issue_code=config.MARKER_ISSUE_CODES["INVALID_ORIENTATION"],
 244:         message=(
 245:             f"Se encontraron {len(resolved)} rotaciones distintas que "
 246:             "resuelven la orientación de forma aparentemente válida; "
 247:             "no se puede autocorregir con confianza."
 248:         ),
 249:     )
 250:     return image, ambiguous_result, 0
 251: 

  3: import json
  4: from dataclasses import dataclass
  5: from pathlib import Path
  6: from typing import Any
  7: 
  8: 
  9: @dataclass(frozen=True)
 10: class TemplateContract:
 11:     """
 12:     Contrato cargado de una plantilla ScanExam.
 13: 
 14:     Este objeto concentra:
 15:     - configuración general de la plantilla
 16:     - centros de respuestas
 17:     - centros de identificación
 18:     - centros de marcadores
 19:     - rutas absolutas a archivos de referencia
 20:     """
 21: 
 22:     template_id: str
 23:     template_dir: Path
 24: 
 25:     config: dict[str, Any]
 26:     answers_centers: dict[str, list[int]]
 27:     student_id_centers: dict[str, list[int]]
 28:     marker_centers: dict[str, list[int]]
 29: 
 30:     template_pdf_path: Path | None
 31:     template_image_path: Path | None
 32: 
 33:     canonical_width: int
 34:     canonical_height: int
 35:     bubble_diameter_px: int
 36:     crop_size_px: int
 37:     analysis_inner_radius_px: int
 38: 
 39: 
 40: def find_project_root() -> Path:
 41:     """
 42:     Busca la raíz del proyecto subiendo carpetas hasta encontrar
 43:     README.md y requirements.txt.
 44:     """
 45:     current = Path(__file__).resolve()
 46: 
 47:     for parent in current.parents:
 48:         if (parent / "README.md").exists() and (parent / "requirements.txt").exists():
 49:             return parent
 50: 
 51:     raise RuntimeError(
 52:         "No se pudo encontrar la raíz del proyecto. "
 53:         "Verifica que README.md y requirements.txt existan en la raíz."
 54:     )
 55: 
 56: 
 57: def load_json(path: Path) -> dict[str, Any]:
 58:     if not path.exists():
 59:         raise FileNotFoundError(f"No se encontró el archivo requerido: {path}")
 60: 
 61:     with path.open("r", encoding="utf-8") as file:
 62:         return json.load(file)
 63: 
 64: 
 65: def resolve_template_file(template_dir: Path, relative_path: str) -> Path:
 66:     """
 67:     Resuelve rutas relativas tomando como base la carpeta de la plantilla.
 68:     """
 69:     return template_dir / relative_path
 70: 
 71: 
 72: def normalize_marker_centers(markers_data: dict[str, Any]) -> dict[str, list[int]]:
 73:     """
 74:     Soporta dos formatos para marcadores.
 75: 
 76:     Formato recomendado:
 77:     {
 78:         "marker_size_px": 100,
 79:         "coordinate_type": "center",
 80:         "markers": {
 81:             "top_left": [180, 180],
 82:             "top_right": [1920, 180],
 83:             ...
 84:         },
 85:         "orientation_marker": "top_right"
 86:     }
 87: 
 88:     Formato simple:
 89:     {
 90:         "top_left": [180, 180],
 91:         "top_right": [1920, 180],
 92:         ...
 93:     }
 94:     """
 95:     if "markers" in markers_data:
 96:         return markers_data["markers"]
 97: 
 98:     return {
 99:         key: value
100:         for key, value in markers_data.items()
101:         if isinstance(value, list) and len(value) == 2
102:     }
103: 
104: 
105: def validate_center_dict(name: str, centers: dict[str, Any]) -> None:
106:     """
107:     Valida que todos los centros tengan formato [x, y].
108:     """
109:     for item_id, center in centers.items():
110:         if not isinstance(center, list) or len(center) != 2:
111:             raise ValueError(
112:                 f"{name}: '{item_id}' debe tener formato [x, y]. Valor recibido: {center}"
113:             )
114: 
115:         x, y = center
116: 
117:         if not isinstance(x, int) or not isinstance(y, int):
118:             raise ValueError(
119:                 f"{name}: '{item_id}' debe usar coordenadas enteras. Valor recibido: {center}"
120:             )
121: 
122: 
123: def load_template(
124:     template_id: str = "ficha_optica_a5_horizontal_v1",
125:     project_root: Path | None = None,
126: ) -> TemplateContract:
127:     """
128:     Carga la plantilla oficial de ScanExam.
129: 
130:     Uso esperado:
131:         template = load_template("ficha_optica_a5_horizontal_v1")
132: 
133:     Devuelve:
134:         - config
135:         - answers_centers
136:         - student_id_centers
137:         - marker_centers
138:         - rutas absolutas a PDF/PNG
139:         - parámetros útiles de tamaño y burbuja
140:     """
141:     if project_root is None:
142:         project_root = find_project_root()
143: 
144:     template_dir = project_root / "data" / "plantilla" / template_id
145:     config_path = template_dir / "template_config.json"
146: 
147:     config = load_json(config_path)
148: 
149:     if config["template_id"] != template_id:
150:         raise ValueError(
151:             f"El template_id solicitado es '{template_id}', "
152:             f"pero el config declara '{config['template_id']}'."
153:         )
154: 
155:     answers_path = resolve_template_file(
156:         template_dir,
157:         config["answers"]["centers_file"]
158:     )
159: 
160:     student_id_path = resolve_template_file(
161:         template_dir,
162:         config["student_id"]["centers_file"]
163:     )
164: 
165:     markers_path = resolve_template_file(
166:         template_dir,
167:         config["perspective"]["markers_file"]
168:     )
169: 
170:     answers_centers = load_json(answers_path)
171:     student_id_centers = load_json(student_id_path)
172:     markers_data = load_json(markers_path)
173:     marker_centers = normalize_marker_centers(markers_data)
174: 
175:     validate_center_dict("answers_centers", answers_centers)
176:     validate_center_dict("student_id_centers", student_id_centers)
177:     validate_center_dict("marker_centers", marker_centers)
178: 
179:     reference_files = config.get("reference_files", {})
180: 
181:     template_pdf_path = None
182:     if "template_pdf" in reference_files:
183:         template_pdf_path = resolve_template_file(
184:             template_dir,
185:             reference_files["template_pdf"]
186:         )
187: 
188:     template_image_path = None
189:     if "template_image" in reference_files:
190:         template_image_path = resolve_template_file(
191:             template_dir,
192:             reference_files["template_image"]
193:         )
194: 
195:     canonical_width = config["canonical_size"]["width_px"]
196:     canonical_height = config["canonical_size"]["height_px"]
197: 
198:     bubble_diameter_px = config["bubble"]["diameter_px"]
199:     crop_size_px = config["bubble"]["crop_size_px"]
200:     analysis_inner_radius_px = config["bubble"]["analysis_inner_radius_px"]
201: 
202:     return TemplateContract(
203:         template_id=template_id,
204:         template_dir=template_dir,
205:         config=config,
206:         answers_centers=answers_centers,
207:         student_id_centers=student_id_centers,
208:         marker_centers=marker_centers,
209:         template_pdf_path=template_pdf_path,
210:         template_image_path=template_image_path,
211:         canonical_width=canonical_width,
212:         canonical_height=canonical_height,
213:         bubble_diameter_px=bubble_diameter_px,
214:         crop_size_px=crop_size_px,
215:         analysis_inner_radius_px=analysis_inner_radius_px,
216:     )
217: 
218: 
219: if __name__ == "__main__":
220:     template = load_template()
221: 
222:     print("Plantilla cargada correctamente:")
223:     print(f"- Template ID: {template.template_id}")
224:     print(f"- Carpeta: {template.template_dir}")
225:     print(f"- Tamaño canónico: {template.canonical_width}x{template.canonical_height}")
226:     print(f"- Respuestas: {len(template.answers_centers)} centros")
227:     print(f"- Identificación: {len(template.student_id_centers)} centros")
228:     print(f"- Marcadores: {len(template.marker_centers)} centros")
229:     print(f"- Crop size: {template.crop_size_px}px")

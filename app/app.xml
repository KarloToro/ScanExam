1053: def process_batch(
1054:     paths: list[str | Path],
1055:     output_root: str | Path,
1056:     template_id: str = config.TEMPLATE_ID,
1057: ) -> list[FichaProcessingResult]:
1058:     """
1059:     Corre process_ficha() sobre una lista de fotos y escribe
1060:     {output_root}/vision_manifest.json con el resultado de todas
1061:     (Decisión 3.1 del equipo).
1062: 
1063:     P2 no construye la estructura completa de BATCH-001/ (eso es de
1064:     P3/core_pipeline.py) — solo escribe dentro de output_root, que
1065:     representa la carpeta work/ del lote.
1066:     """
1067:     output_root = Path(output_root)
1068:     resultados = []
1069: 
1070:     for path in paths:
1071:         resultado = process_ficha(path, template_id=template_id, output_root=output_root)
1072:         resultados.append(resultado)
1073: 
1074:     manifest = [r.manifest_entry for r in resultados]
1075: 
1076:     output_root.mkdir(parents=True, exist_ok=True)
1077:     manifest_path = output_root / "vision_manifest.json"
1078: 
1079:     with manifest_path.open("w", encoding="utf-8") as file:
1080:         json.dump(manifest, file, indent=2, ensure_ascii=False)
1081: 
1082:     return resultados

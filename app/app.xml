 590: # ---------------------------------------------------------------------------
 591: # Fase 3: validación de calidad visual (Anexo C: M1-M4)
 592: # ---------------------------------------------------------------------------
 593: 
 594: @dataclass
 595: class QualityMetrics:
 596:     """Valores crudos de cada métrica, útiles para depuración/calibración."""
 597: 
 598:     sharpness: float
 599:     sharpness_passed: bool
 600: 
 601:     brightness: float
 602:     brightness_passed: bool
 603: 
 604:     dark_area_ratio: float
 605:     dark_area_passed: bool
 606: 
 607:     marker_offsets_px: dict[str, float | None]
 608:     markers_passed: bool
 609: 
 610: 
 611: @dataclass
 612: class QualityValidationResult:
 613:     """
 614:     Resultado de aplicar las métricas M1-M4 (Anexo C) sobre la imagen
 615:     ya canonizada.
 616: 
 617:     status:
 618:         "OK"              -> pasó las 4 métricas.
 619:         "LOW_CONFIDENCE"   -> alguna métrica falló.
 620:     """
 621: 
 622:     status: str
 623:     issue_code: str | None
 624:     message: str
 625:     metrics: QualityMetrics
 626: 
 627: 
 628: def validate_canonical_quality(
 629:     canonical_image: np.ndarray,
 630:     marker_centers: dict[str, list[int]],
 631:     marker_size_px: int = 100,
 632: ) -> QualityValidationResult:
 633:     """
 634:     Aplica las métricas M1 (nitidez), M2 (brillo), M3 (zonas negras) y
 635:     M4 (posición de marcadores) sobre la imagen canónica, tal como
 636:     describe el Anexo C.
 637: 
 638:     Parámetros:
 639:         canonical_image: imagen ya corregida por Fase 2
 640:             (correct_perspective).
 641:         marker_centers: centros oficiales de marcadores._centros.json
 642:             (TemplateContract.marker_centers).
 643:         marker_size_px: tamaño físico del marcador en la plantilla
 644:             (marker_size_px de marcadores_centros.json).
 645: 
 646:     Retorna:
 647:         QualityValidationResult
 648:     """
 649:     gray = cv2.cvtColor(canonical_image, cv2.COLOR_BGR2GRAY)
 650: 
 651:     # --- M1: nitidez ---
 652:     sharpness = float(cv2.Laplacian(gray, cv2.CV_64F).var())
 653:     sharpness_passed = sharpness >= config.QUALITY_MIN_SHARPNESS
 654: 
 655:     # --- M2: brillo ---
 656:     brightness = float(gray.mean())
 657:     brightness_passed = (
 658:         config.QUALITY_MIN_BRIGHTNESS <= brightness <= config.QUALITY_MAX_BRIGHTNESS
 659:     )
 660: 
 661:     # --- M3: zonas negras/vacías ---
 662:     dark_mask = gray < config.QUALITY_DARK_PIXEL_THRESHOLD
 663:     dark_area_ratio = float(dark_mask.sum()) / dark_mask.size
 664:     dark_area_passed = dark_area_ratio <= config.QUALITY_MAX_DARK_AREA_RATIO
 665: 
 666:     # --- M4: verificación de marcadores en posiciones esperadas ---
 667:     marker_offsets: dict[str, float | None] = {}
 668:     markers_passed = True
 669: 
 670:     for name, expected_center in marker_centers.items():
 671:         offset = _measure_marker_offset(
 672:             gray, expected_center, marker_size_px
 673:         )
 674:         marker_offsets[name] = offset
 675: 
 676:         if offset is None or offset > config.QUALITY_MARKER_POSITION_TOLERANCE_PX:
 677:             markers_passed = False
 678: 
 679:     metrics = QualityMetrics(
 680:         sharpness=sharpness,
 681:         sharpness_passed=sharpness_passed,
 682:         brightness=brightness,
 683:         brightness_passed=brightness_passed,
 684:         dark_area_ratio=dark_area_ratio,
 685:         dark_area_passed=dark_area_passed,
 686:         marker_offsets_px=marker_offsets,
 687:         markers_passed=markers_passed,
 688:     )
 689: 
 690:     failed_checks = []
 691: 
 692:     if not sharpness_passed:
 693:         failed_checks.append(f"M1 nitidez ({sharpness:.1f} < {config.QUALITY_MIN_SHARPNESS})")
 694: 
 695:     if not brightness_passed:
 696:         failed_checks.append(f"M2 brillo ({brightness:.1f})")
 697: 
 698:     if not dark_area_passed:
 699:         failed_checks.append(
 700:             f"M3 zonas negras ({dark_area_ratio * 100:.1f}% > "
 701:             f"{config.QUALITY_MAX_DARK_AREA_RATIO * 100:.1f}%)"
 702:         )
 703: 
 704:     if not markers_passed:
 705:         failed_checks.append(f"M4 posición de marcadores ({marker_offsets})")
 706: 
 707:     if failed_checks:
 708:         return QualityValidationResult(
 709:             status="LOW_CONFIDENCE",
 710:             issue_code=config.QUALITY_LOW_CONFIDENCE_ISSUE_CODE,
 711:             message=(
 712:                 "La ficha canonizada no superó los controles mínimos de "
 713:                 f"calidad: {'; '.join(failed_checks)}."
 714:             ),
 715:             metrics=metrics,
 716:         )
 717: 
 718:     return QualityValidationResult(
 719:         status="OK",
 720:         issue_code=None,
 721:         message="La ficha canonizada superó las 4 métricas de calidad.",
 722:         metrics=metrics,
 723:     )
 724: 
 725: 
 726: def _measure_marker_offset(
 727:     gray: np.ndarray,
 728:     expected_center: list[int],
 729:     marker_size_px: int,
 730: ) -> float | None:
 731:     """
 732:     Recorta una región de interés alrededor del centro esperado de un
 733:     marcador (M4) y mide qué tan lejos está el centroide oscuro real
 734:     respecto al centro oficial. Retorna None si no se encontró
 735:     suficiente presencia oscura en la ROI (el marcador se perdió o
 736:     deformó en el warp).
 737:     """
 738:     half = marker_size_px // 2 + config.QUALITY_MARKER_ROI_MARGIN
 739:     cx, cy = expected_center
 740: 
 741:     height, width = gray.shape[:2]
 742: 
 743:     x1 = max(0, int(cx - half))
 744:     y1 = max(0, int(cy - half))
 745:     x2 = min(width, int(cx + half))
 746:     y2 = min(height, int(cy + half))
 747: 
 748:     roi = gray[y1:y2, x1:x2]
 749: 
 750:     if roi.size == 0:
 751:         return None
 752: 
 753:     dark_mask = roi < config.QUALITY_DARK_PIXEL_THRESHOLD
 754:     dark_ratio = float(dark_mask.sum()) / dark_mask.size
 755: 
 756:     if dark_ratio < config.QUALITY_MIN_MARKER_DARK_RATIO:
 757:         return None
 758: 
 759:     ys, xs = np.nonzero(dark_mask)
 760:     centroid_x = x1 + float(xs.mean())
 761:     centroid_y = y1 + float(ys.mean())
 762: 
 763:     offset = float(np.hypot(centroid_x - cx, centroid_y - cy))
 764:     return offset
 765: 

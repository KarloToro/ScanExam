1130: def draw_canonical_debug(canonical_image: np.ndarray, marker_centers: dict[str, list[int]]) -> np.ndarray:
1131:     """
1132:     Dibuja los marcadores oficiales sobre la imagen canónica resultante,
1133:     para verificar visualmente que el warp dejó cada marcador exactamente
1134:     donde marcadores_centros.json dice que debería estar.
1135:     """
1136:     debug_image = canonical_image.copy()
1137: 
1138:     for name, (cx, cy) in marker_centers.items():
1139:         cv2.circle(debug_image, (int(cx), int(cy)), 8, (0, 0, 255), 2)
1140:         cv2.putText(
1141:             debug_image,
1142:             name,
1143:             (int(cx) + 12, int(cy) - 12),
1144:             cv2.FONT_HERSHEY_SIMPLEX,
1145:             0.6,
1146:             (0, 0, 255),
1147:             2,
1148:             cv2.LINE_AA,
1149:         )
1150: 
1151:     return debug_image
